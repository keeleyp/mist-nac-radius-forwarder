; Copy this file to mist-radius.ini and edit the values for your environment.
; mist-radius.ini is gitignored so secrets never get committed.

[server]
listen_host = 0.0.0.0
; Port forwarded through your firewall to this host
listen_port = 8080
; Optional Mist webhook secret (sent as X-Mist-Secret header). Leave blank to disable.
webhook_secret =

[radius]
; FortiGate IP address
radius_host = 172.16.0.12
; RADIUS Accounting port (RFC 2866 default)
radius_port = 1813
; Shared secret — must match FortiGate RSSO config
radius_secret = changeme

[logging]
; Directory where daily log files are written (nac_accounting_YYYY-MM-DD.log)
log_dir = ./logs

[attributes]
; Some NAS/RADIUS-accounting-profile implementations refresh identity cleanly
; on Interim-Update but handle Start/Stop transitions differently. If that's
; what your FortiGate is doing, set this to true to send every packet as
; Interim-Update regardless of the underlying Mist event (Start-only/
; Stop-only attributes like Acct-Session-Time/Acct-Terminate-Cause are still
; included as normal). Deviates from RFC 2866's documented semantics, so it's
; off by default.
force_interim_update = false
